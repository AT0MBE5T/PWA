{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["vite/client", "vite-plugin-pwa/client"],
    "strict": true,

    "moduleResolution": "bundler",
    "module": "ESNext"
  }
}
